################################################################################
#                                                                              #
#                    PATIENT PRE-ASSESSMENT SYSTEM                             #
#                      Environment Configuration                               #
#                                                                              #
#  Copy this file to .env and fill in your actual values.                     #
#  Never commit .env to version control.                                       #
#                                                                              #
################################################################################

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           APPLICATION                                       │
# └────────────────────────────────────────────────────────────────────────────┘
APP_NAME=Patient Pre-Assessment System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                            SECURITY                                         │
# │                                                                             │
# │  AVATAR_API_KEY: Used by Tavus webhooks to authenticate requests           │
# │  Add this key to Tavus webhook headers: X-API-Key: <your-key>              │
# └────────────────────────────────────────────────────────────────────────────┘
AVATAR_API_KEY=your-secure-api-key-here

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                              CORS                                          │
# └────────────────────────────────────────────────────────────────────────────┘
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500,http://127.0.0.1:5500,https://tavus.daily.co,https://*.daily.co,*

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           DATABASE                                          │
# │                                                                             │
# │  PostgreSQL: patient_preassessment                                         │
# │  Table: patients (id, first_name, last_name, phone,                        │
# │                   chief_complaint, created_at)                             │
# └────────────────────────────────────────────────────────────────────────────┘
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patient_preassessment
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_POOL_SIZE=5

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                            TAVUS                                            │
# │                                                                             │
# │  Get these from your Tavus dashboard: https://platform.tavus.io            │
# └────────────────────────────────────────────────────────────────────────────┘
TAVUS_API_KEY=your-tavus-api-key-here
TAVUS_PERSONA_ID=your-persona-id-here
TAVUS_REPLICA_ID=your-replica-id-here
